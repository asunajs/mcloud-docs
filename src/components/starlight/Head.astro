---
const { head } = Astro.locals.starlightRoute;

// 检查是否是密码页面
const isPasswordPage = Astro.url.pathname === '/password' || Astro.url.pathname === '/password/';
---

{head.map(({ tag: Tag, attrs, content }) => <Tag {...attrs} set:html={content} />)}

{!isPasswordPage && (
  <script is:inline>
    // 密码验证脚本
    (function() {
      // 检查是否已验证
      const verified = sessionStorage.getItem('doc_verified');
      if (verified !== 'true') {
        // 重定向到密码页面
        window.location.href = '/mcloud-docs/password';
      }
    })();
  </script>
)}
