---
const { head } = Astro.locals.starlightRoute;

const isPasswordPage = Astro.url.pathname === '/password' || Astro.url.pathname === '/password/';
---

{head.map(({ tag: Tag, attrs, content }) => <Tag {...attrs} set:html={content} />)}

{!isPasswordPage && (
  <script is:inline>
    (function() {
      var verified = sessionStorage.getItem('doc_verified');
      if (verified !== 'true') {
        sessionStorage.setItem('doc_return_to', window.location.pathname + window.location.search + window.location.hash);
        window.location.replace('/password');
      }
    })();
  </script>
)}
